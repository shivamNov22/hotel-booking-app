# Base URL for the axios instance used by RTK Query.
# Left as /api by default so requests hit this app's own Next.js route
# handlers under src/app/api. Point it at a real backend when you have one.
NEXT_PUBLIC_API_BASE_URL=/api

# Used to build absolute URLs in sitemap.xml / robots.txt
NEXT_PUBLIC_SITE_URL=https://example.com
